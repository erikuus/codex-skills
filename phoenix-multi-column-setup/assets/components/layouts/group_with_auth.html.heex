<Layouts.app
  flash={@flash}
  current_scope={@current_scope}
  show_auth_menu={true}
>
  <.multi_column_layout>
    <:narrow_sidebar>
      <Sidebar.menu current_layout={:group} current_scope={@current_scope} />
    </:narrow_sidebar>
    <:mobile_menu>
      <Group.menu id="group-mobile-menu" current_path={@current_path} current_scope={@current_scope} />
    </:mobile_menu>
    <:desktop_menu hook="PreserveScroll">
      <Group.menu id="group-desktop-menu" current_path={@current_path} current_scope={@current_scope} />
    </:desktop_menu>
    {@inner_content}
  </.multi_column_layout>
</Layouts.app>
