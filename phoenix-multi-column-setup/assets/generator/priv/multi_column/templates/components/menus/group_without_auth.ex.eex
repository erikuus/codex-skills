defmodule {{web_module}}.Menus.<%= group_module %> do
  use Phoenix.Component

  import {{web_module}}.BaseComponents

  attr :id, :string, required: true
  attr :current_path, :string

  def menu(assigns) do
    ~H"""
    <.vertical_navigation
      class="px-3"
      id={@id}
      items={get_items(@current_path)}
    />
    """
  end

  defp get_items(current_path) do
    [
<%= items_literal %>
    ]
  end

  defp active_path?(current_path, paths) do
    current_path in paths
  end
end
