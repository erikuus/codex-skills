<Layouts.app flash={@flash}>
  <.multi_column_layout>
    <:narrow_sidebar>
      <Sidebar.menu current_layout={:<%= group_key %>} />
    </:narrow_sidebar>
    <:mobile_menu>
      <<%= group_module %>.menu id="<%= group_key %>-mobile-menu" current_path={@current_path} />
    </:mobile_menu>
    <:desktop_menu hook="PreserveScroll">
      <<%= group_module %>.menu id="<%= group_key %>-desktop-menu" current_path={@current_path} />
    </:desktop_menu>
    {@inner_content}
  </.multi_column_layout>
</Layouts.app>
